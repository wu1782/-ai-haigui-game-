{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksJson": {
      "name": "ai-turtle-soup-server",
      "version": "1.1.0",
      "install": {
        "commands": "npm install"
      },
      "build": {
        "commands": ""
      },
      "start": {
        "commands": "npm start"
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
