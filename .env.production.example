# ============================================
# AI 海龟汤 - 生产环境配置说明
# ============================================

# 复制此文件为 .env.production 然后填写实际值
# Vercel 部署时需要在 Vercel 控制台设置这些环境变量

# ============================================
# 前端配置 (Vercel)
# ============================================

# 生产环境 API 地址（指向 Railway 后端）
# 格式: https://your-app.railway.app
# 注意：末尾不要加斜杠
VITE_API_BASE_URL=https://your-railway-app.railway.app

# DeepSeek API Key（可选，如果前端直接调用 AI）
VITE_API_KEY=your-deepseek-api-key

# ============================================
# 后端配置 (Railway)
# ============================================

# DeepSeek API Key（用于 AI 判定和生成）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# JWT 密钥（生产环境必须修改！使用随机字符串）
JWT_SECRET=your-random-secret-key-at-least-32-chars

# CORS Origins（允许的前端域名，逗号分隔）
# Vercel 域名格式: https://your-app.vercel.app
CORS_ORIGINS=https://your-vercel-app.vercel.app,https://www.your-domain.com

# 服务器端口（Railway 会自动设置 PORT 环境变量）
# PORT=3001
